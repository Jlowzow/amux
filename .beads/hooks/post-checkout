#!/usr/bin/env sh
# br-shim v1
# br-hooks-version: 0.52.0
#
# br (beads) post-checkout hook - thin shim
#
# This shim delegates to 'br hook post-checkout' which contains
# the actual hook logic. This pattern ensures hook behavior is always
# in sync with the installed br version - no manual updates needed.
#
# The 'br hook' command (singular) supports:
# - Guard against frequent firing (only imports if JSONL changed)
# - Per-worktree state tracking
# - Dolt branch-then-merge pattern
# - Hook chaining configuration

# Check if br is available
if ! command -v br >/dev/null 2>&1; then
    # Silently skip - post-checkout is called frequently
    exit 0
fi

exec br hook post-checkout "$@"

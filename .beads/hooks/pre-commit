#!/usr/bin/env sh
# br-shim v1
# br-hooks-version: 0.52.0
#
# br (beads) pre-commit hook - thin shim
#
# This shim delegates to 'br hook pre-commit' which contains
# the actual hook logic. This pattern ensures hook behavior is always
# in sync with the installed br version - no manual updates needed.
#
# The 'br hook' command (singular) supports:
# - Per-worktree export state tracking
# - Dolt branch-then-merge pattern for cell-level conflict resolution
# - Hook chaining configuration

# Check if br is available
if ! command -v br >/dev/null 2>&1; then
    echo "Warning: br command not found in PATH, skipping pre-commit hook" >&2
    echo "  Install br: brew install beads" >&2
    echo "  Or add br to your PATH" >&2
    exit 0
fi

exec br hook pre-commit "$@"
